# ===========================================
# Environment Variables Template
# Copy this file to .env or .env.development and fill in the values
# ===========================================

# PostgreSQL (individual vars for local dev)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=satellite_tracker
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# PostgreSQL (Railway format - takes priority if set)
# DATABASE_URL=postgresql://user:password@host:port/database

# Space-Track.org credentials (https://www.space-track.org)
SPACETRACK_IDENTITY=your_email@example.com
SPACETRACK_PASSWORD=your_password_here

# CORS (comma-separated origins for production)
# CORS_ORIGINS=https://your-frontend.railway.app

# Application
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5152
